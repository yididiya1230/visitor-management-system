{
  "$schema": "https://schema.railpack.com",
  "provider": "dotnet",
  "packages": {
    "dotnet": "10.0"
  },
  "steps": {
    "install": {
      "commands": [
        "dotnet restore ECX.VisitorManagement.slnx"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "dotnet publish ECX.VisitorManagement.slnx --no-restore -c Release -o out"
      ]
    }
  },
  "deploy": {
    "startCommand": "./out/ECX.VisitorManagement.API"
  }
}
