{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "dotnet": "10.0"
  },
  "buildAptPackages": ["libicu-dev"],
  "steps": {
    "install": {
      "commands": [
        "pwd",
        "ls -la",
        "ls -la src/ECX.VisitorManagement.API/ 2>/dev/null || echo 'src dir not found'",
        "find . -name '*.csproj' -o -name '*.slnx' 2>/dev/null | head -20"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "echo BUILD_OK"
      ]
    }
  },
  "deploy": {
    "startCommand": "echo DEPLOY_OK"
  }
}
