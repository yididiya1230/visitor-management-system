{
  "$schema": "https://schema.railpack.com",
  "provider": "dotnet",
  "packages": {
    "dotnet": "10.0"
  },
  "steps": {
    "install": {
      "commands": [
        "pwd && ls -la"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pwd && ls -laR"
      ]
    }
  },
  "deploy": {
    "startCommand": "echo done"
  }
}
